# ── ExpenseTracker environment ──────────────────────────────────────
# Copy this file to .env.local and replace the placeholder values.
#   cp .env.example .env.local

# MongoDB connection string.
# Local instance:   mongodb://localhost:27017/expense-tracker
# Atlas cluster:    mongodb+srv://<user>:<password>@<cluster>.mongodb.net/expense-tracker
# The trailing path segment is the database name used for auth + expenses.
MONGODB_URI="mongodb://localhost:27017/expense-tracker"

# Secret used by NextAuth to encrypt session tokens.
# Generate a real one with:  openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32-output"

# Google OAuth credentials.
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth client ID (type: Web application)
# 3. Authorized JavaScript origin:  http://localhost:3000
# 4. Authorized redirect URI:       http://localhost:3000/api/auth/callback/google
# (For production, add the same two URLs with your deployed domain.)
AUTH_GOOGLE_ID="your-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-client-secret"
